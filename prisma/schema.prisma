// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Campanha {
  id                 String   @id @default(cuid())
  nome               String
  slug               String   @unique
  status             String   @default("ativo") // ativo, pausado, encerrado
  total_votos        Int      @default(0)
  media_consolidada  Float    @default(0)
  last_calc_at       DateTime?
  meta_config        Json?    // Configurações extras (pesos, limites)
  data_inicio        DateTime @default(now())
  data_fim           DateTime?
  
  candidatos         Candidato[]
  atributos          CampanhaAtributo[]

  @@map("campanhas")
}

model Atributo {
  id          String   @id @default(cuid())
  nome        String   @unique
  descricao   String?
  icone       String?
  polaridade  Int      @default(1) // 1: Positivo, -1: Negativo
  visivel     Boolean  @default(true) // Controle de visibilidade no frontend
  
  campanhas   CampanhaAtributo[]
  avaliacoes  Avaliacao[]

  @@map("atributos")
}

model CampanhaAtributo {
  id          String   @id @default(cuid())
  campanha_id String
  atributo_id String
  
  campanha    Campanha @relation(fields: [campanha_id], references: [id])
  atributo    Atributo @relation(fields: [atributo_id], references: [id])

  @@map("campanha_atributos")
}

model Candidato {
  id                 String   @id @default(cuid())
  nome               String
  partido            String?
  numero             String?
  cargo              String
  foto_url           String?
  ano_eleicao        Int      @default(2024)
  cidade             String
  bairro             String?
  status             String   @default("Ativo") // Ativo, Inativo
  status_verificacao Boolean  @default(false)
  total_avaliacoes   Int      @default(0)
  campanha_id        String
  
  campanha           Campanha @relation(fields: [campanha_id], references: [id])
  avaliacoes         Avaliacao[]
  manifestacoes      Manifestacao[]

  @@map("candidatos")
}

model Manifestacao {
  id                 String   @id @default(cuid())
  candidato_id       String
  
  // Indicadores Avançados (Paraná Pesquisas)
  aprovacao          Boolean? // true: aprova, false: desaprova
  expectativa_vitoria Boolean? // true: acredita que vence, false: não
  
  // Perfil do Eleitor
  perfil             Json?    // { idade, sexo, escolaridade, etc }
  
  // Auditoria e Anti-robô
  fingerprint_hash   String
  ip_hash            String
  user_agent         String?
  duration_ms        Int?     
  is_valid           Boolean  @default(true)
  honeypot_triggered Boolean  @default(false)
  
  criado_em          DateTime @default(now())

  candidato          Candidato @relation(fields: [candidato_id], references: [id])
  avaliacoes         Avaliacao[]

  @@index([candidato_id])
  @@index([fingerprint_hash])
  @@map("manifestacoes")
}

model Avaliacao {
  id                 String   @id @default(cuid())
  manifestacao_id    String?  // Relacionamento com a manifestação (sessão)
  candidato_id       String
  atributo_id        String
  valor              Int      // 1 ou -1
  is_valid           Boolean  @default(true)
  
  // Auditoria (Redundância para facilitar consultas legadas se necessário)
  fingerprint_hash   String
  ip_hash            String
  user_agent         String?
  duration_ms        Int?     
  honeypot_triggered Boolean  @default(false)
  device_info        Json?    
  geo_location       Json?    
  
  criado_em          DateTime @default(now())

  manifestacao       Manifestacao? @relation(fields: [manifestacao_id], references: [id])
  candidato          Candidato @relation(fields: [candidato_id], references: [id])
  atributo           Atributo  @relation(fields: [atributo_id], references: [id])

  @@index([candidato_id])
  @@index([manifestacao_id])
  @@map("avaliacoes")
}

model Bloqueio {
  id          String   @id @default(cuid())
  hash        String   @unique // IP ou Fingerprint
  motivo      String?
  expira_em   DateTime?
  criado_em   DateTime @default(now())

  @@map("bloqueios")
}

model AuditLog {
  id          String   @id @default(cuid())
  acao        String   // EX: "VOTO_INVALIDADO", "CAMPANHA_CRIADA"
  entidade    String   // EX: "Avaliacao", "Campanha"
  entidade_id String
  detalhes    Json?
  usuario_id  String?  // ID do Admin (se houver)
  criado_em   DateTime @default(now())

  @@map("audit_logs")
}

model ParametroPlataforma {
  id          String   @id @default(cuid())
  chave       String   @unique
  valor       Json
  grupo       String   @default("geral")
  descricao   String?
  updatedAt   DateTime @updatedAt

  @@map("parametros_plataforma")
}
